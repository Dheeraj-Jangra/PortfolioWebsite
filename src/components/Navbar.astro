---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="fixed top-0 left-0 right-0 z-[1000] bg-canvas/80 dark:bg-dark-canvas/80 backdrop-blur-xl border-b border-hairline dark:border-dark-hairline transition-colors duration-300">
  <div class="max-w-[1280px] mx-auto px-6 md:px-8 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-ink dark:text-dark-ink no-underline">
      <span class="font-mono text-xs tracking-[0.6px] uppercase text-ink/40 dark:text-dark-ink/40">DHRJ</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href="#about" class="nav-link">About</a>
      <a href="#work" class="nav-link">Work</a>
      <a href="#dsa" class="nav-link">DSA</a>
      <a href="#experience" class="nav-link">Experience</a>
      <a href="#contact" class="nav-link">Contact</a>
    </div>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a href="#contact" class="btn-secondary text-sm py-2 px-5 hidden sm:inline-flex">Let's Talk</a>
      <button
        id="menuToggle"
        class="md:hidden w-10 h-10 flex items-center justify-center rounded-full bg-surface-soft dark:bg-dark-surface"
        aria-label="Toggle menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path id="menuLine1" d="M3 6h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path id="menuLine2" d="M3 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobileMenu"
    class="md:hidden fixed inset-0 top-14 bg-canvas dark:bg-dark-canvas z-[999] flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <a href="#about" class="text-2xl font-light text-ink dark:text-dark-ink no-underline mobile-link">About</a>
    <a href="#work" class="text-2xl font-light text-ink dark:text-dark-ink no-underline mobile-link">Work</a>
    <a href="#dsa" class="text-2xl font-light text-ink dark:text-dark-ink no-underline mobile-link">DSA</a>
    <a href="#experience" class="text-2xl font-light text-ink dark:text-dark-ink no-underline mobile-link">Experience</a>
    <a href="#contact" class="text-2xl font-light text-ink dark:text-dark-ink no-underline mobile-link">Contact</a>
    <a href="#contact" class="btn-primary mt-4 mobile-link">Let's Talk</a>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menuToggle");
  const menu = document.getElementById("mobileMenu");
  const line1 = document.getElementById("menuLine1");
  const line2 = document.getElementById("menuLine2");
  let isOpen = false;

  toggle?.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu?.classList.remove("opacity-0", "pointer-events-none");
      menu?.classList.add("opacity-100", "pointer-events-auto");
      line1?.setAttribute("d", "M4 4l10 10");
      line2?.setAttribute("d", "M4 14l10-10");
    } else {
      menu?.classList.add("opacity-0", "pointer-events-none");
      menu?.classList.remove("opacity-100", "pointer-events-auto");
      line1?.setAttribute("d", "M3 6h12");
      line2?.setAttribute("d", "M3 12h12");
    }
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      menu?.classList.add("opacity-0", "pointer-events-none");
      menu?.classList.remove("opacity-100", "pointer-events-auto");
      line1?.setAttribute("d", "M3 6h12");
      line2?.setAttribute("d", "M3 12h12");
    });
  });
</script>
