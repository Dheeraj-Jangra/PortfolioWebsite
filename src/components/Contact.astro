---
---

<section id="contact" class="py-24 md:py-32">
  <div class="max-w-[1280px] mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16">
      <div>
        <span class="eyebrow text-ink/40 dark:text-dark-ink/40 mb-4 block reveal">Get in Touch</span>
        <h2 class="display-lg mb-6 text-ink dark:text-dark-ink reveal" style="transition-delay: 100ms">
          Let's talk
          <span class="relative inline-block">
            <span class="relative z-10">data</span>
            <span class="absolute bottom-1 left-0 w-full h-3 bg-block-lime -z-0 rounded-sm"></span>
          </span>
        </h2>
        <p class="body-lg text-ink/60 dark:text-dark-ink/60 max-w-[400px] mb-10 reveal" style="transition-delay: 200ms">
          Got a dataset that needs wrangling? A dashboard that needs building? Or just want to talk algorithms?
          I'm always open to new challenges.
        </p>

        <div class="space-y-4 reveal" style="transition-delay: 300ms">
          <a href="mailto:dheeraj@example.com" class="flex items-center gap-3 text-ink/60 dark:text-dark-ink/60 hover:text-ink dark:hover:text-dark-ink transition-colors no-underline">
            <span class="w-10 h-10 rounded-full bg-surface-soft dark:bg-dark-surface flex items-center justify-center shrink-0 border border-hairline dark:border-dark-hairline">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2" stroke-linecap="round"/>
                <path d="M22 7l-10 6L2 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="body-sm">dheeraj@example.com</span>
          </a>
          <a href="https://github.com/dheeraj" target="_blank" rel="noopener" class="flex items-center gap-3 text-ink/60 dark:text-dark-ink/60 hover:text-ink dark:hover:text-dark-ink transition-colors no-underline">
            <span class="w-10 h-10 rounded-full bg-surface-soft dark:bg-dark-surface flex items-center justify-center shrink-0 border border-hairline dark:border-dark-hairline">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="body-sm">github.com/dheeraj</span>
          </a>
          <a href="https://linkedin.com/in/dheeraj" target="_blank" rel="noopener" class="flex items-center gap-3 text-ink/60 dark:text-dark-ink/60 hover:text-ink dark:hover:text-dark-ink transition-colors no-underline">
            <span class="w-10 h-10 rounded-full bg-surface-soft dark:bg-dark-surface flex items-center justify-center shrink-0 border border-hairline dark:border-dark-hairline">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="2" y="9" width="4" height="12" stroke-linecap="round"/>
                <circle cx="4" cy="4" r="2" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="body-sm">linkedin.com/in/dheeraj</span>
          </a>
          <a href="https://leetcode.com/dheeraj" target="_blank" rel="noopener" class="flex items-center gap-3 text-ink/60 dark:text-dark-ink/60 hover:text-ink dark:hover:text-dark-ink transition-colors no-underline">
            <span class="w-10 h-10 rounded-full bg-surface-soft dark:bg-dark-surface flex items-center justify-center shrink-0 border border-hairline dark:border-dark-hairline">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="body-sm">leetcode.com/dheeraj</span>
          </a>
        </div>
      </div>

      <div class="reveal-right" style="transition-delay: 200ms">
        <form class="color-block-lime grain relative rounded-lg p-8 space-y-6" id="contactForm">
          <div>
            <label class="eyebrow text-ink/40 dark:text-dark-ink/40 block mb-2">Name</label>
            <input
              type="text"
              name="name"
              required
              class="w-full bg-canvas dark:bg-dark-surface border border-hairline dark:border-dark-hairline rounded-md px-4 py-3 text-body text-ink dark:text-dark-ink outline-none focus:border-ink/40 dark:focus:border-dark-ink/40 transition-colors"
              placeholder="Your name"
            />
          </div>
          <div>
            <label class="eyebrow text-ink/40 dark:text-dark-ink/40 block mb-2">Email</label>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-canvas dark:bg-dark-surface border border-hairline dark:border-dark-hairline rounded-md px-4 py-3 text-body text-ink dark:text-dark-ink outline-none focus:border-ink/40 dark:focus:border-dark-ink/40 transition-colors"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label class="eyebrow text-ink/40 dark:text-dark-ink/40 block mb-2">Message</label>
            <textarea
              name="message"
              rows="4"
              required
              class="w-full bg-canvas dark:bg-dark-surface border border-hairline dark:border-dark-hairline rounded-md px-4 py-3 text-body text-ink dark:text-dark-ink outline-none focus:border-ink/40 dark:focus:border-dark-ink/40 transition-colors resize-none"
              placeholder="Tell me about your data challenge..."
            ></textarea>
          </div>
          <button type="submit" class="btn-primary w-full magnetic-btn">
            Send Message
            <svg class="ml-2 w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 10h14M12 7l3 3-3 3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
    if (btn) {
      btn.textContent = "Message Sent!";
      btn.disabled = true;
      setTimeout(() => {
        btn.innerHTML = `Send Message <svg class="ml-2 w-5 h-5 inline" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 10h14M12 7l3 3-3 3" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        btn.disabled = false;
        (form as HTMLFormElement).reset();
      }, 2000);
    }
  });
</script>
