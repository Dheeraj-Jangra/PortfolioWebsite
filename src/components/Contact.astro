          <a href="https://x.com/helloo_dheeraj" target="_blank" rel="noopener" class="flex items-center gap-3 text-ink/60 dark:text-dark-ink/60 hover:text-ink dark:hover:text-dark-ink transition-colors no-underline">
            <span class="w-10 h-10 rounded-full bg-surface-soft dark:bg-dark-surface flex items-center justify-center shrink-0 border border-hairline dark:border-dark-hairline">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
