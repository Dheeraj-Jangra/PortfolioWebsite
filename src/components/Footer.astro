---
const footerLinks = [
  { heading: "Navigate", links: [
    { label: "About", href: "#about" },
    { label: "Work", href: "#work" },
    { label: "DSA", href: "#dsa" },
    { label: "Experience", href: "#experience" },
    { label: "Contact", href: "#contact" },
  ]},
  { heading: "Social", links: [
    { label: "GitHub", href: "https://github.com/dheeraj" },
    { label: "LinkedIn", href: "https://linkedin.com/in/dheeraj" },
    { label: "LeetCode", href: "https://leetcode.com/dheeraj" },
    { label: "Twitter", href: "https://twitter.com/dheeraj" },
  ]},
  { heading: "Elsewhere", links: [
    { label: "Kaggle", href: "#" },
    { label: "Resume", href: "#" },
    { label: "Blog", href: "#" },
    { label: "Now", href: "#" },
  ]},
];
---

<footer class="py-16 md:py-24 border-t border-hairline dark:border-dark-hairline transition-colors">
  <div class="max-w-[1280px] mx-auto px-6 md:px-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-12 mb-16">
      <div class="reveal">
        <span class="display-lg font-bold tracking-tight text-ink dark:text-dark-ink">DHRJ</span>
        <p class="text-ink/40 dark:text-dark-ink/40 text-sm mt-2 max-w-[280px]">
          Data analyst who writes code that feels as good as it works.
        </p>
      </div>

      <div class="grid grid-cols-3 gap-8 md:gap-16 stagger-children">
        {footerLinks.map((col) => (
          <div class="reveal">
            <span class="caption text-ink/30 dark:text-dark-ink/30 block mb-4">{col.heading}</span>
            <ul class="space-y-2 list-none p-0 m-0">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="body-sm text-ink/50 dark:text-dark-ink/50 hover:text-ink dark:hover:text-dark-ink transition-colors no-underline"
                    target={link.href.startsWith("http") ? "_blank" : undefined}
                    rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-hairline-soft dark:border-dark-hairline-soft">
      <span class="caption text-ink/30 dark:text-dark-ink/30">
        &copy; {new Date().getFullYear()} Dheeraj. All rights reserved.
      </span>
      <span class="caption text-ink/20 dark:text-dark-ink/20">
        Built with Astro, Tailwind &amp; a lot of SQL.
      </span>
    </div>
  </div>
</footer>
