---
const skills = [
  {
    category: "Analysis",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10M12 20V4M6 20v-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Data Analysis & Statistics",
    description: "Turning messy datasets into clean insights. Hypothesis testing, regression, cohort analysis, and A/B test evaluation.",
    tools: ["Python", "R", "SQL", "SciPy", "StatsModels"],
    color: "bg-block-lime",
  },
  {
    category: "Visualization",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" stroke-linecap="round"/><path d="M3 9h18M9 21V9" stroke-linecap="round"/></svg>`,
    title: "Visualization & Dashboards",
    description: "Interactive dashboards and executive-ready reports. From raw data to visual stories that drive decisions.",
    tools: ["Tableau", "Power BI", "Looker", "Matplotlib", "Plotly"],
    color: "bg-block-lilac",
  },
  {
    category: "Engineering",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Vibe Coding",
    description: "Writing scripts and tools that feel good to use. Clean, aesthetic, functional — code that sparks joy.",
    tools: ["Python", "JS/TS", "Streamlit", "FastAPI", "Git"],
    color: "bg-block-mint",
  },
  {
    category: "Algorithms",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10" stroke-linecap="round"/><path d="M12 6v6l4 2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "DSA & Problem Solving",
    description: "500+ problems solved. Graph algorithms, dynamic programming, trees — sharpening the edge of data thinking.",
    tools: ["LeetCode", "C++", "Python", "Graph Theory", "DP"],
    color: "bg-block-cream",
  },
];
---

<section id="skills" class="py-24 md:py-32">
  <div class="max-w-[1280px] mx-auto px-6 md:px-8">
    <div class="mb-16">
      <span class="eyebrow text-ink/40 dark:text-dark-ink/40 mb-4 block reveal">Capabilities</span>
      <h2 class="display-lg max-w-[600px] text-ink dark:text-dark-ink reveal" style="transition-delay: 100ms">
        What I
        <span class="relative inline-block">
          <span class="relative z-10">do</span>
          <span class="absolute bottom-1 left-0 w-full h-3 bg-block-lime -z-0 rounded-sm"></span>
        </span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 stagger-children">
      {skills.map((skill) => (
        <div
          class="reveal group relative p-8 rounded-lg border border-hairline dark:border-dark-hairline bg-canvas dark:bg-dark-surface hover:border-ink/20 dark:hover:border-dark-ink/20 transition-all duration-500"
        >
          <span class="caption text-ink/30 dark:text-dark-ink/30 mb-6 block">{skill.category}</span>

          <div class="flex items-start gap-4 mb-4">
            <div class={`${skill.color} w-12 h-12 rounded-lg flex items-center justify-center shrink-0`}>
              <Fragment set:html={skill.icon} />
            </div>
            <div>
              <h3 class="headline text-xl mb-1 text-ink dark:text-dark-ink">{skill.title}</h3>
              <p class="text-ink/50 dark:text-dark-ink/50 text-sm leading-relaxed">{skill.description}</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mt-6">
            {skill.tools.map((tool) => (
              <span class="px-2.5 py-1 bg-surface-soft dark:bg-dark-surface-elevated rounded-sm text-xs font-mono text-ink/50 dark:text-dark-ink/50 tracking-wider uppercase border border-hairline dark:border-dark-hairline">
                {tool}
              </span>
            ))}
          </div>

          <div class={`absolute bottom-0 left-0 right-0 h-1 ${skill.color} rounded-b-lg scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left`}></div>
        </div>
      ))}
    </div>
  </div>
</section>
