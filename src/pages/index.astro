---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import DSA from '../components/DSA.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <Hero />
  <MarqueeStrip />
  <About />
  <Skills />

  <!-- Color Block CTA Section -->
  <section class="py-8">
    <div class="max-w-[1280px] mx-auto px-6 md:px-8">
      <div class="color-block-navy grain relative rounded-lg overflow-hidden py-20 md:py-28 px-8 md:px-16 text-center">
        <span class="eyebrow text-inverse-ink/40 mb-4 block reveal">Philosophy</span>
        <h2 class="display-lg max-w-[700px] mx-auto text-inverse-ink mb-6 reveal" style="transition-delay: 100ms">
          Good analysis isn't about fancy models — it's about asking the right question and showing the answer clearly.
        </h2>
        <p class="body-lg text-inverse-ink/50 max-w-[500px] mx-auto mb-10 reveal" style="transition-delay: 200ms">
          Every query I write, every chart I build, every insight I deliver is designed to help someone make a better decision.
        </p>
        <div class="reveal" style="transition-delay: 300ms">
          <a href="#contact" class="btn-primary magnetic-btn bg-inverse-ink text-inverse-canvas hover:bg-inverse-ink/90 dark:bg-dark-ink dark:text-dark-canvas dark:hover:bg-dark-ink/90">
            Let's Analyze Together
            <svg class="ml-2 w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 10h10M12 7l3 3-3 3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Projects />
  <DSA />
  <Experience />
  <Contact />
  <Footer />
</Layout>
